{
  "name": "@byrem6/ai-dev-tools",
  "version": "1.0.1",
  "description": "AI Dev Tools (adt) - Token-efficient CLI for AI agents and developers",
  "main": "dist/index.js",
  "bin": {
    "adt": "./bin/adt"
  },
  "type": "commonjs",
  "files": [
    "bin",
    "dist",
    "dist/templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "dev": "tsc && npm run copy-templates && node dist/index.js",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint:check && npm test",
    "copy-templates": "copyfiles -f src/templates/* dist/templates/"
  },
  "keywords": [
    "cli",
    "ai",
    "developer-tools",
    "ast",
    "code-analysis",
    "token-efficient",
    "code-navigation",
    "refactoring",
    "git",
    "search",
    "developer-productivity"
  ],
  "author": "Ramazan Hocaoglu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byrem6/ai-dev-tools.git"
  },
  "bugs": {
    "url": "https://github.com/byrem6/ai-dev-tools/issues"
  },
  "homepage": "https://github.com/byrem6/ai-dev-tools/ai-dev-tools#readme",
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fast-glob": "^3.3.2",
    "glob": "^10.3.10",
    "ignore": "^5.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
